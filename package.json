{
  "name": "@slop-o-meter/root",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @slop-o-meter/app dev",
    "test": "yarn workspace @slop-o-meter/app test",
    "check-types": "yarn workspace @slop-o-meter/app check-types",
    "check-linting": "oxlint",
    "fix-linting": "oxlint --fix",
    "check-formatting": "oxfmt --check",
    "fix-formatting": "oxfmt",
    "build": "yarn workspace @slop-o-meter/app build",
    "deploy:production": "yarn workspace @slop-o-meter/app build && yarn workspace @slop-o-meter/infra deploy",
    "cdk": "yarn workspace @slop-o-meter/infra cdk",
    "playwright-cli": "playwright-cli"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.5",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
